# ================================
# Copy this file to .env.local
# ================================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Drive OAuth2 Configuration
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REFRESH_TOKEN=your_google_oauth_refresh_token
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_google_drive_root_folder_id

# Optional: only used once when running `npm run google:oauth-setup`
GOOGLE_CLIENT_ID_FOR_SETUP=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET_FOR_SETUP=your_google_oauth_client_secret

# Email Provider
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@optimum-production.com
